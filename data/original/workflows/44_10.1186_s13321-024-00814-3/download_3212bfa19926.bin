l class="text-xs block w-full mb-1" for="utm_term"><span>utm_term</span></label><input class="text-sm text-sm border border-gray-300 rounded-md px-3 py-2 w-full" id="utm_term" name="utm_term" type="text" placeholder="" value=""/></div></div><div class="mb-4 hidden"><div class="flex-1 flex flex-col justify-end hidden"><label class="text-xs block w-full mb-1" for="landing_page_url"><span>Landing Page URL</span></label><input class="text-sm text-sm border border-gray-300 rounded-md px-3 py-2 w-full" id="landing_page_url" name="landing_page_url" type="text" placeholder="" value=""/></div></div><div class="mb-4 hidden"><div class="flex-1 flex flex-col justify-end hidden"><label class="text-xs block w-full mb-1" for="pending_salesforce_campaign_id"><span>Salesforce Campaign Id [Pending]</span></label><input class="text-sm text-sm border border-gray-300 rounded-md px-3 py-2 w-full" id="pending_salesforce_campaign_id" name="pending_salesforce_campaign_id" type="text" placeholder="" value="7017T000000PgAQQA0"/></div></div><div class="mb-4 hidden"><div class="flex-1 flex flex-col justify-end hidden"><div class="flex gap-x-4 text-xxs mb-2"><input id="iscreatedmanually__c" name="iscreatedmanually__c" type="checkbox" value="false"/><label class="text-xs block w-full mb-1" for="iscreatedmanually__c"><span>Created Manually</span></label></div></div></div><div class="mb-4 hidden"><div class="flex-1 flex flex-col justify-end hidden"><div class="flex gap-x-4 text-xxs mb-2"><input id="optin__c" name="optin__c" type="checkbox" value="false"/><label class="text-xs block w-full mb-1" for="optin__c"><span>Marketing Email OptIn</span></label></div></div></div><div class="mb-4"><div class="flex-1 flex flex-col justify-end"><div class="flex gap-x-4 text-xxs mb-2"><input id="data_privacy_and_processing" name="data_privacy_and_processing" type="checkbox" required="" value="true"/><label class="text-xs block w-full mb-1" for="data_privacy_and_processing"><span>I have read and accept the <a href="https://www.knime.com/downloads/full-license" target="_blank" rel="noopener">terms and conditions</a> to download KNIME Analytics Platform (open source license) and I accept the <a href="https://www.knime.com/privacy" target="_blank" rel="noopener">Privacy Policy</a>.</span> *</label></div></div></div><div class="mb-4"><div class="flex-1 flex flex-col justify-end"><label class="text-xs block w-full mb-1" for="knime_uses"><span>KNIME uses the information you provide to share relevant content and product updates and to better understand our community. You may unsubscribe from these emails at any time.</span></label><input class="text-sm text-sm border border-gray-300 rounded-md px-3 py-2 w-full" id="knime_uses" name="knime_uses" type="text" placeholder="" value=""/></div></div><div class="mb-4 hidden"></div></div><div class="text-[#888]"></div><button class="hb-button" type="submit">Download</button></form></div></div></div></div><svg xmlns="http://www.w3.org/2000/svg" width="1574px" height="1313px" viewBox="0 0 1574 1313" version="1.1" class="absolute bottom-0 md:bottom-[unset] md:top-0 -right-[720px] md:-right-[900px] lg:-right-[720px] h-80 md:h-auto"><title>Hero Angle Pattern</title><g id="Desktop" stroke="none" stroke-width="1" fill="none" fill-rule="evenodd"><g id="Download-Page:-No-Selections" transform="translate(-595.000000, -99.000000)" fill="#F9F3D8" fill-rule="nonzero"><g id="Page/Content" transform="translate(0.000000, 100.000000)"><g id="Hero-Angle-Pattern" transform="translate(1382.000000, 655.500000) rotate(-270.000000) translate(-1382.000000, -655.500000) translate(726.000000, -131.000000)"><path d="M-2.27373675e-13,1361.81977 L266.090716,0 L1312,911.436794 L1296.9061,916.620761 L-2.27373675e-13,1361.81977 L-2.27373675e-13,1361.81977 Z M278.055473,34.8748351 L24.2096105,1334.0192 L1275.82832,904.36552 L278.055473,34.8748351 L278.055473,34.8748351 Z" id="Shape" transform="translate(656.000000, 680.909886) scale(-1, 1) translate(-656.000000, -680.909886) "></path><path d="M184.55431,1415.35588 L284.988629,309.850967 L1191.8221,949.610979 L184.55431,1415.35588 L184.55431,1415.35588 Z M297.491483,336.910718 L201.73043,1390.99147 L1162.14313,946.912651 L297.491483,336.910718 L297.491483,336.910718 Z" id="Shape" transform="translate(688.188205, 862.603421) scale(-1, 1) translate(-688.188205, -862.603421) "></path><path d="M434.64842,1468.68766 L369.363634,619.935233 L1136.76983,987.747227 L434.64842,1468.68766 L434.64842,1468.68766 Z M382.213474,638.710015 L444.475717,1448.16238 L1114.09239,989.494733 L382.213474,638.710015 L382.213474,638.710015 Z" id="Shape" transform="translate(753.066731, 1044.311445) scale(-1, 1) translate(-753.066731, -1044.311445) "></path><path d="M785.289127,1521.43604 L554.703889,930.360636 L1181.67828,1026.11976 L785.289127,1521.43604 L785.289127,1521.43604 Z M566.951729,940.168176 L787.657114,1505.92267 L1167.06394,1031.82888 L566.951729,940.168176 L566.951729,940.168176 Z" id="Shape" transform="translate(868.191082, 1225.898337) scale(-1, 1) translate(-868.191082, -1225.898337) "></path><path d="M1133.75594,1573 L740.534165,1240.44192 L744.049417,1239.17893 L1225.00886,1066.03847 L1133.75594,1573 L1133.75594,1573 Z M749.027266,1241.97643 L1130.83403,1564.87275 L1219.43767,1072.63149 L749.027266,1241.97643 L749.027266,1241.97643 L749.027266,1241.97643 Z" id="Shape" transform="translate(982.771513, 1319.519233) scale(-1, 1) translate(-982.771513, -1319.519233) "></path></g></g></g></g></svg></div><div class="px-6 md:px-14 mb-12 md:mb-24 pt-12 md:pt-16 container-alt lg:pt-20"><div class="mx-auto max-w-7xl"><h2 class="mx-auto max-w-3xl text-center block font-heading text-2xl md:text-3xl lg:text-4xl md:leading-tight mb-9 md:mb-16">Here&#x27;s what customers love about KNIME</h2><div class="grid lg:grid-cols-3 gap-4 md:gap-7"></div></div></div><div class="pb-3 md:py-16 lg:py-24 pt-12 relative content-text-bg w-full px-6 md:pl-14 md:pr-36 lg:px-14"><div class="w-full"><div style="margin-top:0px"><script>
(function() {
    'use strict';
    
    if (typeof window.knimeFormHandlerLoaded !== 'undefined') return;
    window.knimeFormHandlerLoaded = true;
    
    let isAttached = false;
    
    function setupFormTimeoutHandler() {
        if (isAttached) return true;
        
        const form = document.querySelector('form.hb-form');
        const submitButton = document.querySelector('button.hb-button[type="submit"]');
        
        if (!form || !submitButton) {
            return false;
        }
        
        isAttached = true;
        
        let redirectHandled = false;
        let timeoutStarted = false;
        
        submitButton.addEventListener('click', function(e) {
            if (timeoutStarted) return;
            
            // Check if email is filled
            const emailInput = form.querySelector('input[name="email"]');
            if (!emailInput || !emailInput.value.trim()) {
                return; // Don't start timeout if email is empty
            }

            // Check if the required checkbox is ticked
            const consentCheckbox = form.querySelector('input[name="data_privacy_and_processing"]');
            if (!consentCheckbox || !consentCheckbox.checked) {
                return; // Don't start timeout if checkbox not checked
            }
            
            timeoutStarted = true;
            
            setTimeout(function() {
                if (!redirectHandled) {
                    createTokenAndRedirect(form);
                }
            }, 6000);
        }, true);
        
        window.addEventListener('beforeunload', function() {
            redirectHandled = true;
        });
        
        return true;
    }
    
    function createTokenAndRedirect(form) {
        const formData = new FormData(form);
        const data = {};
        formData.forEach((value, key) => {
            data[key] = value;
        });
        
        const endpoint = atob('aHR0cHM6Ly93d3cua25pbWUuY29tL2VkZ2UtZnVuY3Rpb25zL2NyZWF0ZS10b2tlbg==');
        
        fetch(endpoint, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(data)
        })
        .then(response => response.ok ? response.text() : Promise.reject())
        .then(tokenResponse => {
            let token;
            try {
                const parsed = JSON.parse(tokenResponse);
                token = parsed.hash || tokenResponse;
            } catch (e) {
                token = tokenResponse;
            }
            
            window.location.href = 'https://www.knime.com/downloads/download-knime?token=' + token;
        })
        .catch(() => {});
    }
    
    function tryInit(attempts) {
        attempts = attempts || 0;
        
        if (setupFormTimeoutHandler()) {
            return;
        }
        
        if (attempts < 100) {
            setTimeout(function() {
                tryInit(attempts + 1);
            }, 200);
        }
    }
    
    setTimeout(function() {
        tryInit();
    }, 1000);
})();
</script>

