}
.hb-form label[for="data_privacy_and_processing"] span,
.hb-form label[for="data_privacy_and_processing"] a,
.hb-form label[for="data_and_privacy_permissions"] span,
.hb-form label[for="data_and_privacy_permissions"] a,
